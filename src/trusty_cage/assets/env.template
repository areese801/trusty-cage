# trusty-cage configuration
#
# This file was created by `trusty-cage init`.
# Uncomment and edit any values you want to customize.
# Environment variables and CLI flags take precedence over these values.

# HTTPS URL of your dotfiles repo (cloned into each new container)
# TRUSTY_CAGE_DOTFILES_REPO=https://github.com/youruser/dotfiles

# Python version installed via pyenv in the container
# TRUSTY_CAGE_PYTHON_VERSION=3.12

# Default shell inside the container
# TRUSTY_CAGE_DEFAULT_SHELL=zsh

# Authentication mode: api_key or subscription
# TRUSTY_CAGE_DEFAULT_AUTH_MODE=api_key

# tmux prefix key inside containers (default Ctrl-a to avoid conflict with host Ctrl-b)
# TRUSTY_CAGE_TMUX_PREFIX=C-a
